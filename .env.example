# ──────────────────────────────────────────────
# LINE Bot Settings
# ──────────────────────────────────────────────

# Channel Secret — ดูได้ที่ LINE Developers > Channel > Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here

# Channel Access Token — ดูได้ที่ LINE Developers > Channel > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# LIFF ID — ดูได้ที่ LINE Developers > LIFF
LIFF_ID=your_liff_id_here

# ──────────────────────────────────────────────
# Admin Settings
# ──────────────────────────────────────────────

# LINE User ID ของเจ้าของ (คุณปาม)
# วิธีหา: ไปที่ LINE Developers > Channel > Messaging API > แล้วส่งข้อความหา Bot
#         แล้วดู log จะเห็น userId ของคุณ
OWNER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Google Sheets Settings
# ──────────────────────────────────────────────

# Spreadsheet ID — เลข ID ใน URL ของ Google Sheets
# เช่น https://docs.google.com/spreadsheets/d/[ID นี้]/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Service Account JSON — ดาวน์โหลดจาก Google Cloud Console
# วิธีทำ: ดูขั้นตอนใน README.md
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
